# ClubOS Backend API Configuration Example
# Copy this file to the project root as `.env` and fill in your Databricks credentials.

# API Server Configuration
CLUBOS_API_HOST=0.0.0.0
CLUBOS_API_PORT=8000

# Databricks Live Mode Configuration
# Required for live Databricks SQL queries. Get these from your ~/.databrickscfg profile.
CLUBOS_DATABRICKS_HOST=https://your-workspace-url.cloud.databricks.com
CLUBOS_DATABRICKS_TOKEN=your-personal-access-token
CLUBOS_DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/warehouse-id
CLUBOS_DATABRICKS_CATALOG=
CLUBOS_DATABRICKS_SCHEMA=

# Local Snapshot Mode (Optional)
# When set, backend reads from local CSV/Parquet/JSON files instead of Databricks.
# Defaults to data/gold_snapshots if not set.
# CLUBOS_GOLD_SNAPSHOT_DIR=/path/to/gold_snapshots

# AI Integration (Optional)
CLUBOS_AI_PROVIDER=
CLUBOS_AI_API_KEY=

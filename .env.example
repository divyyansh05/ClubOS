# ══════════════════════════════════════════════════
# ClubOS Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ══════════════════════════════════════════════════

# ── Databricks (leave empty to use snapshot/CSV mode) ──
# When empty: app runs on local CSV snapshots automatically
CLUBOS_DATABRICKS_HOST=
CLUBOS_DATABRICKS_HTTP_PATH=
CLUBOS_DATABRICKS_TOKEN=

# ── App Configuration ─────────────────────────────────
# PORT is set automatically by Cloud Run — do not set manually
PORT=8080

# Override snapshot directory (optional)
CLUBOS_SNAPSHOT_DIR=

# Override frontend dist path (optional)
CLUBOS_FRONTEND_DIST=

# CORS allowed origins (* = all, for demo use)
CLUBOS_CORS_ORIGINS=*
